    "# ==================== CELL 5: FINAL FIXED VERSION (Consistent Features) ====================\n",
    "import numpy as np\n",
    "import librosa\n",
    "from glob import glob\n",
    "from tqdm import tqdm\n",
    "import pandas as pd\n",
    "import os\n",
    "\n",
    "def extract_features(audio, sr):\n",
    "    features = []\n",
    "    \n",
    "    # 1. MFCCs (40 mean + 40 std = 80)\n",
    "    mfcc = librosa.feature.mfcc(y=audio, sr=sr, n_mfcc=40)\n",
    "    features.extend(np.mean(mfcc, axis=1))\n",
    "    features.extend(np.std(mfcc, axis=1))\n",
    "    \n",
    "    # 2. Chroma (12)\n",
    "    chroma = librosa.feature.chroma_stft(y=audio, sr=sr)\n",
    "    features.extend(np.mean(chroma, axis=1))\n",
    "    \n",
    "    # 3. Spectral Contrast (6)\n",
    "    try:\n",
    "        spec_contrast = librosa.feature.spectral_contrast(y=audio, sr=sr, n_bands=6, fmin=100)\n",
    "        features.extend(np.mean(spec_contrast, axis=1))\n",
    "    except:\n",
    "        features.extend([0.0] * 6)\n",
    "    \n",
    "    # 4. Spectral Features (5)\n",
    "    cent = librosa.feature.spectral_centroid(y=audio, sr=sr)\n",
    "    features.append(np.mean(cent))\n",
    "    features.append(np.std(cent))\n",
    "    \n",
    "    bandwidth = librosa.feature.spectral_bandwidth(y=audio, sr=sr)\n",
    "    features.append(np.mean(bandwidth))\n",
    "    \n",
    "    rolloff = librosa.feature.spectral_rolloff(y=audio, sr=sr)\n",
    "    features.append(np.mean(rolloff))\n",
    "    \n",
    "    # 5. Energy & Temporal (2)\n",
    "    rms = librosa.feature.rms(y=audio)\n",
    "    features.append(np.mean(rms))\n",
    "    \n",
    "    zcr = librosa.feature.zero_crossing_rate(y=audio)\n",
    "    features.append(np.mean(zcr))\n",
    "    \n",
    "    # 6. Delta MFCC (40) - Safe\n",
    "    if mfcc.shape[1] >= 9:\n",
    "        delta_mfcc = librosa.feature.delta(mfcc, width=9)\n",
    "        features.extend(np.mean(delta_mfcc, axis=1))\n",
    "    else:\n",
    "        features.extend([0.0] * 40)\n",
    "    \n",
    "    # FORCE FIXED LENGTH (Total should be 80 + 12 + 6 + 5 + 2 + 40 = 145 features)\n",
    "    if len(features) != 145:\n",
    "        features = features[:145] + [0.0] * (145 - len(features))\n",
    "    \n",
    "    return np.array(features, dtype=np.float32)\n",
    "\n",
    "# ==================== Dataset Creation ====================\n",
    "def create_ml_dataset():\n",
    "    feature_list = []\n",
    "    labels = []\n",
    "    \n",
    "    AUDIO_PATH = '/kaggle/input/datasets/vbookshelf/respiratory-sound-database/Respiratory_Sound_Database/Respiratory_Sound_Database/audio_and_txt_files/'\n",
    "    wav_files = glob(AUDIO_PATH + '*.wav')\n",
    "    \n",
    "    print(f\"Found {len(wav_files)} files...\")\n",
    "    \n",
    "    for wav_path in tqdm(wav_files, desc=\"Extracting Features\"):\n",
    "        base_name = os.path.basename(wav_path)[:-4]\n",
    "        ann_path = AUDIO_PATH + base_name + '.txt'\n",
    "        \n",
    "        if not os.path.exists(ann_path):\n",
    "            continue\n",
    "            \n",
    "        ann = pd.read_csv(ann_path, sep='\\t', header=None, \n",
    "                         names=['start', 'end', 'crackles', 'wheezes'])\n",
    "        \n",
    "        audio_full, sr = librosa.load(wav_path, sr=None)\n",
    "        \n",
    "        for _, row in ann.iterrows():\n",
    "            start = float(row['start'])\n",
    "            end = float(row['end'])\n",
    "            if end - start < 0.5:\n",
    "                continue\n",
    "                \n",
    "            segment = audio_full[int(start * sr): int(end * sr)]\n",
    "            \n",
    "            if len(segment) < 2048 or np.max(np.abs(segment)) < 0.01:\n",
    "                continue\n",
    "                \n",
    "            crackle = int(row['crackles'])\n",
    "            wheeze = int(row['wheezes'])\n",
    "            label = crackle * 2 + wheeze\n",
    "            \n",
    "            feat = extract_features(segment, sr)\n",
    "            feature_list.append(feat)\n",
    "            labels.append(label)\n",
    "    \n",
    "    X = np.array(feature_list, dtype=np.float32)\n",
    "    y = np.array(labels, dtype=np.int32)\n",
    "    \n",
    "    return X, y\n",
    "\n",
    "# ==================== RUN ====================\n",
    "X_ml, y_ml = create_ml_dataset()\n",
    "\n",
    "print(f\"\\n✅ Feature Extraction Completed Successfully!\")\n",
    "print(f\"Total samples: {len(y_ml)}\")\n",
    "print(f\"Features per sample: {X_ml.shape[1]}\")   # Should show 145\n",
    "print(\"\\nClass Distribution:\")\n",
    "print(pd.Series(y_ml).value_counts())"
   ]
