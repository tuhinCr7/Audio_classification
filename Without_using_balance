    "# ==================== CELL 4: Create Dataset ====================\n",
    "def create_dataset():\n",
    "    features = []\n",
    "    labels = []\n",
    "    \n",
    "    wav_files = glob(AUDIO_PATH + '*.wav')\n",
    "    print(f\"Found {len(wav_files)} wav files. Starting processing...\")\n",
    "    \n",
    "    for wav_path in tqdm(wav_files, desc=\"Processing audio\"):\n",
    "        base_name = os.path.basename(wav_path)[:-4]\n",
    "        ann_path = AUDIO_PATH + base_name + '.txt'\n",
    "        \n",
    "        if not os.path.exists(ann_path):\n",
    "            continue\n",
    "            \n",
    "        # Read annotation\n",
    "        ann = pd.read_csv(ann_path, sep='\\t', header=None, \n",
    "                         names=['start', 'end', 'crackles', 'wheezes'])\n",
    "        \n",
    "        # Load audio\n",
    "        audio, sr = librosa.load(wav_path, sr=None)\n",
    "        \n",
    "        for _, row in ann.iterrows():\n",
    "            start = float(row['start'])\n",
    "            end = float(row['end'])\n",
    "            duration = end - start\n",
    "            \n",
    "            if duration < 0.5:\n",
    "                continue\n",
    "                \n",
    "            # Extract segment\n",
    "            start_sample = int(start * sr)\n",
    "            end_sample = int(end * sr)\n",
    "            segment = audio[start_sample:end_sample]\n",
    "            \n",
    "            # Create label: 0=normal, 1=crackle, 2=wheeze, 3=both\n",
    "            crackle = int(row['crackles'])\n",
    "            wheeze = int(row['wheezes'])\n",
    "            label = crackle * 2 + wheeze\n",
    "            \n",
    "            # Mel Spectrogram\n",
    "            mel_spec = librosa.feature.melspectrogram(y=segment, sr=sr, n_mels=128, fmax=8000)\n",
    "            mel_spec_db = librosa.power_to_db(mel_spec, ref=np.max)\n",
    "            \n",
    "            # Resize to 128x128\n",
    "            if mel_spec_db.shape[1] < 128:\n",
    "                pad_width = 128 - mel_spec_db.shape[1]\n",
    "                mel_spec_db = np.pad(mel_spec_db, ((0,0), (0, pad_width)), mode='constant')\n",
    "            else:\n",
    "                mel_spec_db = mel_spec_db[:, :128]\n",
    "            \n",
    "            features.append(mel_spec_db)\n",
    "            labels.append(label)\n",
    "    \n",
    "    return np.array(features), np.array(labels)\n",
    "\n",
    "# Run it\n",
    "X, y = create_dataset()\n",
    "\n",
    "print(f\"\\n✅ Total samples created: {len(y)}\")\n",
    "print(\"Class distribution:\\n\", pd.Series(y).value_counts())"
   ]
