mean(delta_mfcc, axis=1))\n    else:\n        features.extend([0.0] * 40)\n    \n    # FORCE FIXED LENGTH (Total should be 80 + 12 + 6 + 5 + 2 + 40 = 145 features)\n    if len(features) != 145:\n        features = features[:145] + [0.0] * (145 - len(features))\n    \n    return np.array(features, dtype=np.float32)\n\n# ==================== Dataset Creation ====================\ndef create_ml_dataset():\n    feature_list = []\n    labels = []\n    \n    AUDIO_PATH = '/kaggle/input/datasets/vbookshelf/respiratory-sound-database/Respiratory_Sound_Database/Respiratory_Sound_Database/audio_and_txt_files/'\n    wav_files = glob(AUDIO_PATH + '*.wav')\n    \n    print(f\"Found {len(wav_files)} files...\")\n    \n    for wav_path in tqdm(wav_files, desc=\"Extracting Features\"):\n        base_name = os.path.basename(wav_path)[:-4]\n        ann_path = AUDIO_PATH + base_name + '.txt'\n        \n        if not os.path.exists(ann_path):\n            continue\n            \n        ann = pd.read_csv(ann_path, sep='\\t', header=None, \n                         names=['start', 'end', 'crackles', 'wheezes'])\n        \n        audio_full, sr = librosa.load(wav_path, sr=None)\n        \n        for _, row in ann.iterrows():\n            start = float(row['start'])\n            end = float(row['end'])\n            if end - start < 0.5:\n                continue\n                \n            segment = audio_full[int(start * sr): int(end * sr)]\n            \n            if len(segment) < 2048 or np.max(np.abs(segment)) < 0.01:\n                continue\n                \n            crackle = int(row['crackles'])\n            wheeze = int(row['wheezes'])\n            label = crackle * 2 + wheeze\n            \n            feat = extract_features(segment, sr)\n            feature_list.append(feat)\n            labels.append(label)\n    \n    X = np.array(feature_list, dtype=np.float32)\n    y = np.array(labels, dtype=np.int32)\n    \n    return X, y\n\n# ==================== RUN ====================\nX_ml, y_ml = create_ml_dataset()\n\nprint(f\"\\n✅ Feature Extraction Completed Successfully!\")\nprint(f\"Total samples: {len(y_ml)}\")\nprint(f\"Features per sample: {X_ml.shape[1]}\")   # Should show 145\nprint(\"\\nClass Distribution:\")\nprint(pd.Series(y_ml).value_counts())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-21T08:08:35.245520Z","iopub.execute_input":"2026-04-21T08:08:35.246150Z","iopub.status.idle":"2026-04-21T08:16:48.257935Z","shell.execute_reply.started":"2026-04-21T08:08:35.246121Z","shell.execute_reply":"2026-04-21T08:16:48.257191Z"}},"outputs":[{"name":"stdout","text":"Found 920 files...\n","output_type":"stream"},{"name":"stderr","text":"Extracting Features:   0%|          | 4/920 [00:02<08:23,  1.82it/s]/usr/local/lib/python3.12/dist-packages/librosa/core/pitch.py:103: UserWarning: Trying to estimate tuning from empty frequency set.\n  return pitch_tuning(\nExtracting Features:   1%|          | 5/920 [00:02<08:35,  1.77it/s]/usr/local/lib/python3.12/dist-packages/librosa/core/pitch.py:103: UserWarning: Trying to estimate tuning from empty frequency set.\n  return pitch_tuning(\nExtracting Features:   1%|          | 7/920 [00:03<08:29,  1.79it/s]/usr/local/lib/python3.12/dist-packages/librosa/core/pitch.py:103: UserWarning: Trying to estimate tuning from empty frequency set.\n  return pitch_tuning(\nExtracting Features:   1%|          | 9/920 [00:05<08:52,  1.71it/s]/usr/local/lib/python3.12/dist-packages/librosa/core/pitch.py:103: UserWarning: Trying to estimate tuning from empty frequency set.\n  return pitch_tuning(\nExtracting Features:   1%|          | 10/920 [00:05<09:05,  1.67it/s]/usr/local/lib/python3.12/dist-packages/librosa/core/pitch.py:103: UserWarning: Trying to estimate tuning from empty frequency set.\n  return pitch_tuning(\nExtracting Features:   2%|▏         | 14/920 [00:07<07:55,  1.90it/s]/usr/local/lib/python3.12/dist-packages/librosa/core/pitch.py:103: UserWarning: Trying to estim