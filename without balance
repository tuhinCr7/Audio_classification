np.max)\n            \n            # Resize to 128x128\n            if mel_spec_db.shape[1] < 128:\n                pad_width = 128 - mel_spec_db.shape[1]\n                mel_spec_db = np.pad(mel_spec_db, ((0,0), (0, pad_width)), mode='constant')\n            else:\n                mel_spec_db = mel_spec_db[:, :128]\n            \n            features.append(mel_spec_db)\n            labels.append(label)\n    \n    return np.array(features), np.array(labels)\n\n# Run it\nX, y = create_dataset()\n\nprint(f\"\\n✅ Total samples created: {len(y)}\")\nprint(\"Class distribution:\\n\", pd.Series(y).value_counts())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-21T08:07:03.461293Z","iopub.execute_input":"2026-04-21T08:07:03.461535Z","iopub.status.idle":"2026-04-21T08:08:35.243441Z","shell.execute_reply.started":"2026-04-21T08:07:03.461511Z","shell.execute_reply":"2026-04-21T08:08:35.242390Z"}},"outputs":[{"name":"stdout","text":"Found 920 wav files. Starting processing...\n","output_type":"stream"},{"name":"stderr","text":"Processing audio:   1%|▏         | 12/920 [00:02<03:08,  4.81it/s]/usr/local/lib/python3.12/dist-packages/librosa/feature/spectral.py:2148: UserWarning: Empty filters detected in mel frequency basis. Some channels will produce empty responses. Try increasing your sampling rate (and fmax) or reducing n_mels.\n  mel_basis = filters.mel(sr=sr, n_fft=n_fft, **kwargs)\nProcessing audio:   3%|▎         | 25/920 [00:03<02:35,  5.75it/s]/usr/local/lib/python3.12/dist-packages/librosa/feature/spectral.py:2148: UserWarning: Empty filters detected in mel frequency basis. Some channels will produce empty responses. Try increasing your sampling rate (and fmax) or reducing n_mels.\n  mel_basis = filters.mel(sr=sr, n_fft=n_fft, **kwargs)\nProcessing audio:   4%|▍         | 36/920 [00:05<03:29,  4.21it/s]/usr/local/lib/python3.12/dist-packages/librosa/feature/spectral.py:2148: UserWarning: Empty filters detected in mel frequency basis. Some chann